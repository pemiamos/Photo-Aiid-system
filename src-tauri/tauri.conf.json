{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Photo-Aiid-system",
  "version": "3.1.3",
  "identifier": "com.stardust.photo-aiid",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/backend"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese"]
      },
      "wix": {
        "language": "zh-CN"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
